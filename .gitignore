# 가상환경 폴더 (용량 너무 커서 안 올림)
venv/

# 환경변수 파일 (비밀번호 들어있어서 절대 안 올림)
.env
.env.local

# 파이썬 찌꺼기 파일들
__pycache__/
*.pyc

# pytest 캐시 (로컬·하위 폴더 공통, 재실행 시 자동 생성)
.pytest_cache/
pytest-cache-files-*/

# Claude Code 로컬 작업 파일 (공유 설정인 .claude/settings.json 은 제외하고 ignore)
.claude/worktrees/
.claude/settings.local.json

# 시장조사·수출전략 생성 PDF (로컬/Render 디스크·DB 기준 — Git 추적 제외)
upharma-au/reports/**/*.pdf