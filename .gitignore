# 가상환경 폴더 (용량 너무 커서 안 올림)
venv/

# 환경변수 파일 (비밀번호 들어있어서 절대 안 올림)
.env
.env.local

# 파이썬 찌꺼기 파일들
__pycache__/
*.pyc

# pytest 캐시 (로컬·하위 폴더 공통, 재실행 시 자동 생성)
.pytest_cache/
pytest-cache-files-*/

# Claude Code 로컬 작업 파일 (공유 설정인 .claude/settings.json 은 제외하고 ignore)
.claude/worktrees/
.claude/settings.local.json

# 시장조사·수출전략 생성 PDF (로컬/Render 디스크·DB 기준 — Git 추적 제외)
upharma-au/reports/**/*.pdf

# buyer_discovery — 일회성 디버그·로컬 스모크 테스트·임시 스크립트 (저장소 제외)
upharma-au/buyer_discovery/**/_debug_*.py
upharma-au/buyer_discovery/**/_test_*.py
upharma-au/buyer_discovery/**/test_*.py
upharma-au/buyer_discovery/**/_probe_*.py
upharma-au/buyer_discovery/**/_audit_*.py
upharma-au/buyer_discovery/**/_merge_*.py

# buyer_discovery 실행 리포트 (각 실행마다 변동, DB 가 진본)
upharma-au/buyer_discovery/seeds/stage2_scoring_report.json
upharma-au/buyer_discovery/seeds/refresh_revenue_report.json
upharma-au/buyer_discovery/seeds/verify_factory_report.json